# Build output
bin/
obj/
*.user

# Deployment secrets (see .env.example for the expected keys)
.env

# Node deps for rig/ scripts (npm install, not committed)
rig/node_modules/

# Game install + steamcmd (74 GB, managed by steamcmd - never stage)
rig/server/
rig/steamcmd/

# Regenerable extraction/render artifacts
data/*.s2geo
data/*.glb
data/*.png
data/*.bin
data/*.nav
data/*.entities.json
data/*.navareas.json
data/*.viewer-map.json
data/cache/
data/previews/

# Python bytecode (rig/ calibration scripts)
__pycache__/
*.pyc

# High-volume capture telemetry (rotated, regenerable from live runs)
data/calib/captures*.jsonl

# Live IPC mailbox files (transient protocol state)
data/calib/request.json
data/calib/*-request.json
data/calib/stop-request
data/calib/request.json.bad

# Tracked on purpose (hand-made calibration ground truth):
#   data/calib/markers.json
#   data/throws.json
#   data/throw-constants.json
#   data/validation/
data/calib/rig.log
data/calib/watcher.heartbeat

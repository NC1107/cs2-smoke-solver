# Shared configuration for the calibration rig: sourced by rig scripts and
# systemd user units (EnvironmentFile). One place to change when anything
# relocates. systemd does not expand ~ or %h in EnvironmentFile, so paths
# are absolute.
CS2_RIG_DIR=/home/npc/cs2-rig
SMOKESOLVER_REPO=/home/npc/Documents/projects/cs2-smoke-solver
SMOKESOLVER_CALIB_DIR=/home/npc/Documents/projects/cs2-smoke-solver/data/calib
CS2_SERVER_PORT=27021
# Which map the rig comes up on, and the community addon to mount for it (empty
# for stock maps). flatgrass is where the flight constants are measured.
CS2_START_MAP=flatgrass
CS2_ADDON=
VIEWER_PORT=8137
DOTNET_ROOT=/home/npc/.dotnet
PATH=/home/npc/.dotnet:/usr/local/bin:/usr/bin:/bin
